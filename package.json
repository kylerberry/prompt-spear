{
  "name": "prompt-spear",
  "version": "0.1.1",
  "description": "CLI tool that audits LLM endpoints against prompt injection and jailbreak attack categories.",
  "license": "Apache-2.0",
  "author": "Kyler Berry",
  "homepage": "https://github.com/kylerberry/prompt-spear#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylerberry/prompt-spear.git"
  },
  "bugs": {
    "url": "https://github.com/kylerberry/prompt-spear/issues"
  },
  "keywords": [
    "llm",
    "ai-security",
    "prompt-injection",
    "jailbreak",
    "security-testing",
    "ci",
    "audit",
    "openai",
    "anthropic",
    "red-team"
  ],
  "type": "module",
  "bin": {
    "prompt-spear": "dist/cli.js"
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
